---
import { Icon } from "astro-icon/components";
import { externalNotebooksConfig } from "@/config/externalNotebooksConfig";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

export async function getStaticPaths() {
	return [{ params: { notebook: "daily", id: "entry" } }];
}

const { notebook, id } = Astro.params;
---

<MainGridLayout title="远程笔记" description="查看远程笔记详情">
	<div class="remote-entry-container">
		<div class="entry-header">
			<button id="back-btn" class="back-btn">
				<Icon name="material-symbols:arrow-back" />
				返回列表
			</button>
		</div>

		<div class="entry-content" id="entry-content">
			<div class="loading-state">
				<Icon name="svg-spinners:ring-resize" class="loading-icon" />
				<span>加载中...</span>
			</div>
		</div>
	</div>
</MainGridLayout>

<script is:inline>
	const CONFIG = {
		notebookGists: externalNotebooksConfig.notebookGists,
	};

	function getUrlParam(name) {
		const urlParams = new URLSearchParams(window.location.search);
		return urlParams.get(name);
	}

	async function loadEntry() {
		const notebook = getUrlParam("nb") || "{notebook}";
		const id = getUrlParam("id") || "{id}";
		const gistId = CONFIG.notebookGists[notebook];

		if (!gistId) {
			document.getElementById("entry-content").innerHTML = `
				<div class="error-state">
					<Icon name="material-symbols:error" />
					<p>笔记本未配置</p>
				</div>
			`;
			return;
		}

		try {
			const response = await fetch(`https://gist.githubusercontent.com/raw/${gistId}/notebooks-entries.json`);
			
			if (!response.ok) {
				throw new Error('Failed to fetch');
			}

			const data = await response.json();
			const entry = data.entries.find(e => e.id === id);

			if (!entry) {
				document.getElementById("entry-content").innerHTML = `
					<div class="error-state">
						<Icon name="material-symbols:error" />
						<p>笔记不存在</p>
					</div>
				`;
				return;
			}

			document.title = entry.title;
			document.getElementById("entry-content").innerHTML = `
				<article class="entry-article">
					<h1 class="entry-title">${entry.title}</h1>
					<div class="entry-meta">
						<span class="entry-date">📅 ${entry.date}</span>
						<span class="entry-notebook">📒 ${entry.notebook}</span>
					</div>
					<div class="entry-body" id="entry-body"></div>
				</article>
			`;

			document.getElementById("entry-body").innerHTML = marked.parse(entry.content);
		} catch (error) {
			document.getElementById("entry-content").innerHTML = `
				<div class="error-state">
					<Icon name="material-symbols:error" />
					<p>加载失败: ${error.message}</p>
				</div>
			`;
		}
	}

	document.getElementById("back-btn").addEventListener("click", () => {
		window.history.back();
	});

	document.addEventListener('DOMContentLoaded', loadEntry);
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<style>
	.remote-entry-container {
		max-width: 800px;
		margin: 0 auto;
		padding: 20px;
	}

	.entry-header {
		margin-bottom: 24px;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 20px;
		background: var(--btn-regular-bg);
		color: var(--text-color);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		cursor: pointer;
		font-size: 0.875rem;
	}

	.back-btn:hover {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.entry-content {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: var(--radius-large);
		padding: 24px;
	}

	.loading-state, .error-state {
		text-align: center;
		padding: 40px;
		color: var(--content-meta);
	}

	.loading-icon {
		font-size: 3rem;
		margin-bottom: 16px;
		animation: spin 1s linear infinite;
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	.entry-article {
		max-width: 100%;
	}

	.entry-title {
		font-size: 1.75rem;
		font-weight: 600;
		margin-bottom: 16px;
	}

	.entry-meta {
		display: flex;
		gap: 16px;
		margin-bottom: 24px;
		font-size: 0.875rem;
		color: var(--content-meta);
	}

	.entry-body {
		line-height: 1.8;
	}

	.entry-body h1, .entry-body h2, .entry-body h3 {
		margin-top: 24px;
		margin-bottom: 12px;
	}

	.entry-body h1 { font-size: 1.5rem; }
	.entry-body h2 { font-size: 1.25rem; }
	.entry-body h3 { font-size: 1.125rem; }

	.entry-body p {
		margin-bottom: 16px;
	}

	.entry-body ul, .entry-body ol {
		padding-left: 24px;
		margin-bottom: 16px;
	}

	.entry-body blockquote {
		border-left: 4px solid var(--primary);
		padding-left: 16px;
		margin: 16px 0;
		color: var(--content-meta);
		background: var(--bg);
		padding: 12px 16px;
		border-radius: 0 var(--radius) var(--radius) 0;
	}

	.entry-body code {
		background: var(--bg);
		padding: 2px 6px;
		border-radius: 4px;
		font-family: monospace;
	}

	.entry-body pre {
		background: var(--bg);
		padding: 16px;
		border-radius: var(--radius);
		overflow-x: auto;
		margin: 16px 0;
	}

	.entry-body pre code {
		background: transparent;
		padding: 0;
	}

	.entry-body img {
		max-width: 100%;
		border-radius: var(--radius);
		margin: 16px 0;
	}

	.entry-body hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 24px 0;
	}
</style>